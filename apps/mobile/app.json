{
  "expo": {
    "name": "Crew Up",
    "slug": "crewup",
    "scheme": "crewup",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2F6BFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crewup.app"
    },
    "android": {
      "package": "com.crewup.app",
      "adaptiveIcon": {
        "backgroundColor": "#2F6BFF"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
